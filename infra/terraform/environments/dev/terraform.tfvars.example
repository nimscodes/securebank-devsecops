aws_region  = "us-east-1"
environment = "dev"

project_name = "securebank"

availability_zones = ["us-east-1a", "us-east-1b"]

vpc_cidr                 = "10.20.0.0/16"
public_subnet_cidrs      = ["10.20.0.0/24", "10.20.1.0/24"]
private_app_subnet_cidrs = ["10.20.10.0/24", "10.20.11.0/24"]
private_db_subnet_cidrs  = ["10.20.20.0/24", "10.20.21.0/24"]

# Disabled by default to avoid NAT gateway cost in dev.
enable_nat_gateway = false

# Enabled so private ECS tasks can pull ECR images and write logs without NAT.
enable_private_service_endpoints = true

# Operational alarms are planned in Phase 5D. Add SNS topic ARNs later when notification routing exists.
enable_cloudwatch_alarms = true
alarm_actions            = []

# Optional ALB access logging. Leave disabled until you intentionally accept S3 log storage cost.
enable_alb_access_logs          = false
alb_access_logs_bucket_name     = null
alb_access_logs_prefix          = "alb"
alb_access_logs_retention_days  = 30

web_image = "985059095414.dkr.ecr.us-east-1.amazonaws.com/securebank-dev-web:latest"
api_image = "985059095414.dkr.ecr.us-east-1.amazonaws.com/securebank-dev-api:latest"

web_desired_count = 1
api_desired_count = 1

database_name            = "securebank"
database_master_username = "securebank_admin"

db_instance_class          = "db.t4g.micro"
db_allocated_storage       = 20
db_max_allocated_storage   = 100
db_multi_az                = false
db_deletion_protection     = false
db_backup_retention_period = 1
db_skip_final_snapshot     = true

tags = {
  Owner = "platform"
}
