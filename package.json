{
  "name": "securebank",
  "version": "0.1.0",
  "private": true,
  "description": "SecureBank DevSecOps portfolio monorepo",
  "workspaces": [
    "apps/web",
    "apps/api"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
